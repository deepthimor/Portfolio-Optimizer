APP_NAME="AI Portfolio Optimizer"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=True
LOG_LEVEL="INFO"

DATABASE_URL="postgresql://portfolio_user:secure_password_here@localhost:5432/portfolio_db"
DATABASE_URL_ASYNC="postgresql+asyncpg://portfolio_user:secure_password_here@localhost:5432/portfolio_db"
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600

ALPHA_VANTAGE_API_KEY="your_alpha_vantage_key_here"
NEWS_API_KEY="your_newsapi_key_here"
FMP_API_KEY="your_fmp_key_here"
POLYGON_API_KEY="your_polygon_key_here"

REDDIT_CLIENT_ID="your_reddit_client_id"
REDDIT_CLIENT_SECRET="your_reddit_client_secret"
REDDIT_USER_AGENT="AI Portfolio Optimizer v0.1"

TWITTER_API_KEY="your_twitter_api_key"
TWITTER_API_SECRET="your_twitter_api_secret"
TWITTER_ACCESS_TOKEN="your_twitter_access_token"
TWITTER_ACCESS_SECRET="your_twitter_access_secret"
TWITTER_BEARER_TOKEN="your_twitter_bearer_token"

JWT_SECRET_KEY="your_super_secret_jwt_key_change_this_in_production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_PER_MINUTE=60

MODEL_SAVE_PATH="./models/saved_models"
CHECKPOINT_PATH="./models/checkpoints"
BATCH_SIZE=32
LEARNING_RATE=0.001
MAX_EPOCHS=100
EARLY_STOPPING_PATIENCE=10
DEVICE="cpu"

DATA_COLLECTION_INTERVAL=60
DEFAULT_TICKERS="AAPL,GOOGL,MSFT,AMZN,TSLA,META,NVDA,JPM,V,WMT"
HISTORICAL_DATA_YEARS=5
MAX_NEWS_ARTICLES_PER_DAY=100
NEWS_SOURCES="bloomberg,reuters,financial-times,cnbc,wall-street-journal"
REDDIT_SUBREDDITS="wallstreetbets,stocks,investing"
REDDIT_POST_LIMIT=100

CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE="UTC"

RISK_FREE_RATE=0.04
MAX_POSITION_SIZE=0.30
MIN_POSITION_SIZE=0.05
MAX_SECTOR_EXPOSURE=0.40
REBALANCE_THRESHOLD=0.05

COMMISSION_RATE=0.001
SLIPPAGE_RATE=0.0005
INITIAL_CAPITAL=100000

MLFLOW_TRACKING_URI="http://localhost:5000"
WANDB_API_KEY="your_wandb_api_key"
WANDB_PROJECT="portfolio-optimizer"
SENTRY_DSN="your_sentry_dsn_here"

FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"